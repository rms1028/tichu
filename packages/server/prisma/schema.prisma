generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// ── 유저 ────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  guestId       String?  @unique           // 게스트 로그인 ID
  firebaseUid   String?  @unique           // Firebase Auth UID (소셜 로그인)
  nickname      String
  avatarId      String   @default("dragon")
  cardBackId    String   @default("classic")
  coins         Int      @default(500)
  xp            Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 전적
  totalGames    Int      @default(0)
  wins          Int      @default(0)
  losses        Int      @default(0)
  tichuSuccess  Int      @default(0)
  tichuFail     Int      @default(0)
  largeTichuSuccess Int  @default(0)
  largeTichuFail    Int  @default(0)
  oneTwoFinish  Int      @default(0)
  winStreak     Int      @default(0)
  maxWinStreak  Int      @default(0)

  // 랭킹
  rankXp           Int      @default(0)       // 랭크 XP (Iron~Dragon 판별)
  highestXp        Int      @default(0)       // 역대 최고 XP
  currentTier      String   @default("iron")  // 현재 티어
  highestTier      String   @default("iron")  // 역대 최고 티어

  // 탈주/어뷰징
  suspicionScore   Int      @default(0)       // 의심 점수 (0~100)
  leaveCount24h    Int      @default(0)       // 최근 24시간 탈주 횟수
  lastLeaveAt      DateTime?                  // 마지막 탈주 시간
  matchCooldownUntil DateTime?                // 매칭 제한 해제 시간
  lastActiveAt     DateTime @default(now())   // 마지막 활동 시간

  // 상점
  ownedAvatars     String   @default("dragon")         // 쉼표 구분 ID 목록
  ownedCardBacks   String   @default("classic")        // 쉼표 구분 ID 목록
  equippedAvatar   String   @default("dragon")
  equippedCardBack String   @default("classic")

  // 관계
  sentRequests     FriendRequest[]  @relation("SentRequests")
  receivedRequests FriendRequest[]  @relation("ReceivedRequests")
  friendsA         Friendship[]     @relation("FriendA")
  friendsB         Friendship[]     @relation("FriendB")
  sentReports      Report[]         @relation("Reporter")
  receivedReports  Report[]         @relation("Reported")
  blockedUsers     Block[]          @relation("Blocker")
  blockedByUsers   Block[]          @relation("Blocked")
  gameResults      GameResult[]
  seasonRankings   SeasonRanking[]
  pushTokens       PushToken[]

  @@index([nickname])
}

// ── 친구 요청 ───────────────────────────────────────────────

model FriendRequest {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  from      User     @relation("SentRequests", fields: [fromId], references: [id])
  to        User     @relation("ReceivedRequests", fields: [toId], references: [id])
  createdAt DateTime @default(now())

  @@unique([fromId, toId])
}

// ── 친구 관계 ───────────────────────────────────────────────

model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  userA     User     @relation("FriendA", fields: [userAId], references: [id])
  userB     User     @relation("FriendB", fields: [userBId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userAId, userBId])
}

// ── 게임 결과 ───────────────────────────────────────────────

model GameResult {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  roomId        String
  won           Boolean
  team          String               // "team1" | "team2"
  score         Int                  // 내 팀 점수
  opponentScore Int                  // 상대 팀 점수
  tichuDeclared String?              // "large" | "small" | null
  tichuSuccess  Boolean  @default(false)
  finishRank    Int                  // 1~4등
  roundCount    Int      @default(1)
  xpGained      Int      @default(0)      // 획득/차감 XP
  xpBreakdown   String?                   // JSON: XpBreakdown
  tierBefore    String?                    // 게임 전 티어
  tierAfter     String?                    // 게임 후 티어
  abusingFlags  String?                    // JSON: string[]
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
}

// ── 시즌 ────────────────────────────────────────────────────

model Season {
  id        String   @id @default(cuid())
  number    Int      @unique
  name      String                       // "시즌 1", "봄 시즌" 등
  startDate DateTime
  endDate   DateTime
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  rankings  SeasonRanking[]
}

model SeasonRanking {
  id           String   @id @default(cuid())
  seasonId     String
  season       Season   @relation(fields: [seasonId], references: [id])
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  ratingPoints Int      @default(1000)   // 시즌 레이팅
  wins         Int      @default(0)
  losses       Int      @default(0)
  gamesPlayed  Int      @default(0)
  peakRating   Int      @default(1000)
  rewardClaimed Boolean @default(false)
  updatedAt    DateTime @updatedAt

  @@unique([seasonId, userId])
  @@index([seasonId, ratingPoints])
}

// ── 신고 ────────────────────────────────────────────────────

model Report {
  id           String   @id @default(cuid())
  reporterId   String
  reportedId   String
  reason       String                       // "afk" | "abuse" | "cheating" | "other"
  description  String?
  reporter     User     @relation("Reporter", fields: [reporterId], references: [id])
  reported     User     @relation("Reported", fields: [reportedId], references: [id])
  createdAt    DateTime @default(now())

  @@index([reportedId, createdAt])
}

// ── 차단 ────────────────────────────────────────────────────

model Block {
  id         String   @id @default(cuid())
  blockerId  String
  blockedId  String
  blocker    User     @relation("Blocker", fields: [blockerId], references: [id])
  blocked    User     @relation("Blocked", fields: [blockedId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([blockerId, blockedId])
}

// ── 푸시 토큰 ──────────────────────────────────────────────

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String                       // "ios" | "android" | "web"
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
