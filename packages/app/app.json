{
  "expo": {
    "name": "Tichu",
    "slug": "tichu",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/icon.png",
    "scheme": "tichu",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#1a472a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tichu.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a472a"
      },
      "package": "com.tichu.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png",
      "name": "TICHU — Ultimate Card Battle",
      "shortName": "TICHU",
      "description": "티츄 온라인 멀티플레이어 카드 게임. 친구들과 함께 전략적인 카드 배틀을 즐겨보세요!",
      "lang": "ko",
      "themeColor": "#1a472a",
      "backgroundColor": "#1a472a"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a472a",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "14dad48b-5cd4-41b3-a05b-eb3ee73db858"
      }
    },
    "owner": "rms1028"
  }
}
